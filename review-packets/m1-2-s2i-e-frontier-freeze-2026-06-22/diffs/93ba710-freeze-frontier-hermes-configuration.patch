+def hermes_version() -> str:
+    hermes = shutil.which("hermes")
+    if not hermes:
+        return ""
+    result = subprocess.run([hermes, "--version"], check=False, capture_output=True, text=True, timeout=15)
+    return (result.stdout or result.stderr).strip()
