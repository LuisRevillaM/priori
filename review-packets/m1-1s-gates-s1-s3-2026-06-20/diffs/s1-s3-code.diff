+def frame_signal_from_values(
+    *,
+    output: CatalogOutput,
+    frame_ids: list[int],
+    values: list[Any],
+) -> FrameSignal:
+    normalized = [_normalize_missing(item) for item in values]
+    return FrameSignal(
+        frame_ids=frame_ids,
+        values=normalized,
+        unknown_mask=[item is None for item in normalized],
+        unit=output.unit,
+        entity_scope=output.entity_scope,
+    )
