+    frame_id: int,
+    status: str,
+    *,
+    relation_count: int,
+    witness_relation_id: str | None,
+) -> dict[str, Any]:
+    return {
+        "result_id": anchor_id,
+        "anchor_id": anchor_id,
+        "match_id": "J03WOY",
+        "period": "firstHalf",
+        "anchor_frame_id": frame_id,
+        "evaluation_status": status,
+        "relation_count": relation_count,
+        "witness_relation_id": witness_relation_id,
