+}
+
+.canvasShell {
+  width: 100%;
+  overflow: auto;
+  border: 1px solid #bdc6ba;
+  border-radius: 8px;
+  background: #477556;
+}
+
+.canvasShell canvas {
+  display: block;
+  max-width: 100%;
+}
+
+.replayControls {
+  display: grid;
+  grid-template-columns: 74px 74px 74px minmax(160px, 1fr);
+  gap: 8px;
+  align-items: center;
+  margin-top: 10px;
+}
+
+.replayControls button {
+  height: 32px;
+  border-radius: 7px;
+}
+
+.replayControls input {
+  width: 100%;
+}
+
+.detailGrid {
