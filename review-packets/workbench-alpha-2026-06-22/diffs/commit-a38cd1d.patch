+  gap: 7px;
+}
+
+.evidenceRow,
+.traceRow {
+  display: grid;
+  gap: 4px;
+  padding: 8px 0;
+  border-top: 1px solid var(--line);
+}
+
+.evidenceRow span,
+.traceRow span {
+  font-size: 12px;
+  font-weight: 700;
+}
+
+.evidenceRow small,
+.traceRow small {
+  overflow: auto;
+  color: var(--muted);
+  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
+  font-size: 11px;
+  line-height: 1.35;
+}
+
+.evidenceRow code {
+  display: block;
+  overflow: hidden;
+  text-overflow: ellipsis;
+  color: #28332b;
+  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
+  font-size: 12px;
+  white-space: nowrap;
+}
+
+.resultItem {
+  min-height: 68px;
+}
+
+.emptyState {
+  min-height: 60px;
+  display: grid;
+  place-items: center;
+  border: 1px dashed #c7c9c2;
+  border-radius: 8px;
+  color: var(--muted);
+  font-size: 12px;
+  text-align: center;
+  padding: 12px;
+}
+
+.stateBox {
+  margin-bottom: 10px;
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: 10px;
+  font-size: 12px;
+  line-height: 1.45;
+}
+
+.stateBox p {
+  margin: 7px 0 0;
+}
+
+.stateBox.warn {
+  border-color: #d5bc83;
+  background: #fbf5e8;
+}
+
+.stateBox.bad,
+.errorBanner {
+  border-color: #d2a29b;
+  background: #fbefed;
+}
+
+.errorBanner {
+  margin-top: 12px;
+  border: 1px solid #d2a29b;
+  border-radius: 8px;
+  padding: 10px 12px;
+  color: var(--bad);
+  font-size: 13px;
+  font-weight: 650;
+}
+
+@media (max-width: 1180px) {
+  .workspaceGrid {
+    grid-template-columns: 320px minmax(0, 1fr);
+  }
+
+  .rightRail {
+    grid-column: 1 / -1;
+    display: grid;
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+  }
+}
+
+@media (max-width: 820px) {
+  .appShell {
+    padding: 10px;
+  }
+
+  .topbar {
+    align-items: start;
+    flex-direction: column;
+  }
+
+  .workspaceGrid,
+  .detailGrid,
+  .rightRail {
+    grid-template-columns: 1fr;
+  }
+
+  .replayControls {
+    grid-template-columns: repeat(3, 1fr);
+  }
+
+  .replayControls input {
+    grid-column: 1 / -1;
+  }
+}
