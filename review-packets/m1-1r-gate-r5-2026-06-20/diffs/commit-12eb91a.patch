+def approved_recipe_predicate_ids() -> set[str]:
+    payload = clone_plan_payload(APPROVED_PLAN_PATH)
+    return {
+        node["node_id"]
+        for node in payload["draft_plan"]["nodes"]
+        if node.get("kind") == "predicate"
+    }
