+def parameter_definition(
+    name: str,
+    payload_type: str,
+    unit: str,
+    value: float,
+    description: str,
+) -> dict[str, Any]:
+    return {
+        "name": name,
+        "payload_type": payload_type,
+        "unit": unit,
+        "required": False,
+        "default": {"payload_type": payload_type, "unit": unit, "value": value},
+        "description": description,
+    }
+
