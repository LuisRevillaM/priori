        "name": "analysis_rate_hz",
        "payload_type": "number",
        "unit": "hertz",
        "required": false,
        "default": {
          "payload_type": "number",
          "unit": "hertz",
          "value": 5
        },
        "description": "Analysis cadence."
      },
      {
        "name": "minimum_possession_seconds",
        "payload_type": "number",
        "unit": "second",
        "required": false,
        "default": {
          "payload_type": "number",
          "unit": "second",
          "value": 5.0
        },
        "description": "Minimum active-ball possession duration."
      },
      {
        "name": "maximum_analysis_gap_ms",
        "payload_type": "number",
        "unit": "millisecond",
        "required": false,
        "default": {
          "payload_type": "number",
          "unit": "millisecond",
          "value": 250
        },
        "description": "Maximum permitted gap in the analysis stream."
