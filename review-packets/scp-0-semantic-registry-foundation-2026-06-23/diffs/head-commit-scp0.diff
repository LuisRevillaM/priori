+        type: {container: FrameSignal, value: Enum, quantity: controlled_pass_status, unit: none, entity_scope: possession}
+      - name: forward_progression_m
+        type: {container: FrameSignal, value: Scalar, quantity: forward_progression, unit: metre, entity_scope: possession}
+      - name: anchors
+        type: {container: EpisodeSet, value: AnchorRef, quantity: controlled_pass_anchor, unit: none, entity_scope: anchor}
+    lowering: [event_tracking_alignment_candidate, physical_ball_release, physical_ball_reception, possession_continuity]
+    claim_contract_ref: claim.controlled_ball_transfer.v1
+    evidence_contract_ref: evidence.controlled_ball_transfer.v1
+
+  - id: op.ball_lateral_fraction.v1
