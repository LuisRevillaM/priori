+      - name: fraction
+        type: {container: FrameSignal, value: Scalar, quantity: pitch_width_fraction, unit: fraction, entity_scope: ball}
+    lowering: [coordinate_transform, normalized_lateral_position]
+    claim_contract_ref: claim.wide_ball_entry.v1
+    evidence_contract_ref: evidence.wide_ball_entry.v1
+
+  - id: op.defensive_outfield_centroid.v1
