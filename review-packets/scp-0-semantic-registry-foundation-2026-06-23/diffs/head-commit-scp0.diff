+    description: Measure defensive centroid movement toward the ball side relative to a baseline.
+    concept_refs: [concept.defensive_block_lateral_shift]
+    semantic_basis: DETERMINISTIC
+    required_modalities: [tracking]
+    applicability: [possession_anchor_available, defensive_centroid_available]
+    inputs:
+      - name: possession_episodes
+        type: {container: EpisodeSet, value: Boolean, quantity: possession, unit: none, entity_scope: possession}
+      - name: entry_episodes
+        type: {container: EpisodeSet, value: Boolean, quantity: wide_entry, unit: none, entity_scope: ball}
+      - name: defensive_centroid
+        type: {container: FrameSignal, value: Scalar, quantity: lateral_position, unit: metre, entity_scope: team}
+    outputs:
+      - name: signed_shift
+        type: {container: FrameSignal, value: Scalar, quantity: lateral_shift, unit: metre, entity_scope: team}
+      - name: anchors
+        type: {container: EpisodeSet, value: AnchorRef, quantity: shift_anchor, unit: none, entity_scope: anchor}
+    lowering: [baseline_selection, signed_difference, anchor_projection]
+    claim_contract_ref: claim.defensive_block_lateral_shift.v1
+    evidence_contract_ref: evidence.defensive_block_lateral_shift.v1
+
+  - id: op.reviewed_block_shift_outcome.v1
+    kind: Operationalization
+    display_name: Reviewed Block-Shift Outcome
