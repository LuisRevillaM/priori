+    required_modalities: [tracking]
+    applicability: [relation_episode_available, reviewed_plan_context]
+    inputs:
+      - name: relation_episodes
+        type: {container: RelationEpisodeSet, value: RelationRef, quantity: relation_episode, unit: none, entity_scope: relation}
+    outputs:
+      - name: classification
+        type: {container: FrameSignal, value: Enum, quantity: reviewed_destination_entry_classification, unit: none}
+    lowering: [recipe_rule_set, dynamic_region_membership]
+    claim_contract_ref: claim.relation_destination_entry.v1
+    evidence_contract_ref: evidence.relation_destination_entry.v1
+
+  - id: op.geometric_progressive_corridor.v1
+    kind: Operationalization
+    display_name: Geometric Progressive Corridor
+    description: Represent a clear forward connection from ball location to attacking teammate over an interval.
+    concept_refs: [concept.progressive_connection_availability]
+    semantic_basis: DETERMINISTIC
+    required_modalities: [tracking]
+    applicability: [anchor_available, attacking_teammates_available, defending_outfield_available]
+    inputs:
+      - name: anchors
