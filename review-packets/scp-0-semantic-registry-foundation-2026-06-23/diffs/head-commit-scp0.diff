+  - id: op.release_reception_opponent_transition_count.v1
+    kind: Operationalization
+    display_name: Release-Reception Opponent Transition Count
+    description: Count opposition outfield players goal-side of the ball at release and behind the ball at controlled reception.
+    concept_refs: [concept.opponent_ball_side_transition_count]
