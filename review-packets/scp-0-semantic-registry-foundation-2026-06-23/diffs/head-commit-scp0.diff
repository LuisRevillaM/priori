+    outputs:
+      - name: entry_status
+        type: {container: FrameSignal, value: Enum, quantity: destination_entry_status, unit: none, entity_scope: relation}
+    lowering: [dynamic_region_membership, temporal_window, tri_state_thresholding]
+    claim_contract_ref: claim.relation_destination_entry.v1
+    evidence_contract_ref: evidence.relation_destination_entry.v1
+
