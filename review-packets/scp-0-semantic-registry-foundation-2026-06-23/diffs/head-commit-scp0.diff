+    semantic_basis: DETERMINISTIC
+    required_modalities: [tracking, events]
+    applicability: [accepted_shift_episode]
+    inputs:
+      - name: accepted_shift_episodes
+        type: {container: EpisodeSet, value: Boolean, quantity: accepted_shift, unit: none}
+    outputs:
