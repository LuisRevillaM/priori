+    claim_contract_ref: claim.possession_context.v1
+    evidence_contract_ref: evidence.possession_context.v1
+    tags: [possession, anchor]
+
+  - id: concept.controlled_ball_transfer
+    kind: Concept
+    display_name: Controlled Ball Transfer
+    description: The ball moves from one player to a teammate and the teammate gains controlled possession.
+    claim_contract_ref: claim.controlled_ball_transfer.v1
+    evidence_contract_ref: evidence.controlled_ball_transfer.v1
+    tags: [pass, control, event_tracking_alignment]
+
+  - id: concept.wide_ball_entry
+    kind: Concept
+    display_name: Wide Ball Entry
+    description: The ball occupies a configured wide area under a declared pitch-width policy.
+    claim_contract_ref: claim.wide_ball_entry.v1
+    evidence_contract_ref: evidence.wide_ball_entry.v1
+    tags: [width, ball_position]
+
+  - id: concept.defensive_outfield_centroid
+    kind: Concept
+    display_name: Defensive Outfield Centroid
+    description: The aggregate position of defending outfield players, excluding the goalkeeper.
+    claim_contract_ref: claim.defensive_outfield_centroid.v1
+    evidence_contract_ref: evidence.defensive_outfield_centroid.v1
+    tags: [defending, shape]
+
+  - id: concept.defensive_block_lateral_shift
+    kind: Concept
+    display_name: Defensive Block Lateral Shift
+    description: Baseline-relative lateral movement of a defending outfield block toward the ball side.
+    claim_contract_ref: claim.defensive_block_lateral_shift.v1
+    evidence_contract_ref: evidence.defensive_block_lateral_shift.v1
+    tags: [defending, block_shift]
+
+  - id: concept.reviewed_outcome_classification
+    kind: Concept
+    display_name: Reviewed Outcome Classification
+    description: A saved-plan classification rule whose assumptions are controlled by a reviewed tactical recipe.
+    claim_contract_ref: claim.reviewed_outcome_classification.v1
+    evidence_contract_ref: evidence.reviewed_outcome_classification.v1
+    tags: [classification, reviewed_plan_only]
+
+  - id: concept.progressive_connection_availability
+    kind: Concept
+    display_name: Progressive Connection Availability
+    description: A geometrically clear forward connection from the ball or anchor to a teammate.
+    claim_contract_ref: claim.progressive_connection_availability.v1
+    evidence_contract_ref: evidence.progressive_connection_availability.v1
+    tags: [corridor, progression, relation]
+
+  - id: concept.relation_destination_entry
+    kind: Concept
+    display_name: Relation Destination Entry
+    description: Ball entry into the destination region defined by a relation episode within a declared window.
+    claim_contract_ref: claim.relation_destination_entry.v1
+    evidence_contract_ref: evidence.relation_destination_entry.v1
+    tags: [destination_entry, relation, temporal]
+
+  - id: concept.opponent_ball_side_transition_count
+    kind: Concept
+    display_name: Opponent Ball-Side Transition Count
+    description: Count of opposition outfield players whose position relative to the ball changes between action endpoints.
+    claim_contract_ref: claim.opponent_ball_side_transition_count.v1
+    evidence_contract_ref: evidence.opponent_ball_side_transition_count.v1
+    tags: [bypass, action, count]
+
+  - id: concept.high_bypass_completed_pass
+    kind: Concept
+    display_name: High-Bypass Completed Pass
+    description: A controlled completed pass with sufficient forward progression and opponent bypass count.
+    claim_contract_ref: claim.high_bypass_completed_pass.v1
+    evidence_contract_ref: evidence.high_bypass_completed_pass.v1
+    tags: [bypass, pass, recipe]
+
+  - id: concept.ai_corridor_destination_composition
+    kind: Concept
+    display_name: AI Corridor Destination Composition
+    description: A validated AI-authored composition combining possession anchors, corridor availability, and destination entry.
+    claim_contract_ref: claim.ai_corridor_destination_composition.v1
+    evidence_contract_ref: evidence.ai_corridor_destination_composition.v1
+    tags: [ai_authored, corridor, destination_entry]
+
+operationalizations:
+  - id: op.possession_segment_intervals.v1
+    kind: Operationalization
+    display_name: Possession Segment Intervals
+    description: Identify active-ball possession intervals and anchors for the perspective team.
+    concept_refs: [concept.possession_context]
+    semantic_basis: INFERRED_CANDIDATE
+    required_modalities: [tracking, events]
+    applicability: [ball_in_play_candidate, perspective_team_known]
+    inputs:
+      - name: canonical_match_state
+        type: {container: WorldState, value: MatchState, unit: none}
