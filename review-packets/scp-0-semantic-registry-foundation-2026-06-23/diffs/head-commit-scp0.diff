+        type: {container: RelationEpisodeSet, value: RelationRef, quantity: progressive_corridor, unit: none, entity_scope: relation}
+      - name: anchor_evaluations
+        type: {container: EpisodeSet, value: Boolean, quantity: anchor_relation_evaluation, unit: none, entity_scope: anchor}
+    lowering: [segment_geometry, clearance_measurement, relation_episode_extraction]
+    claim_contract_ref: claim.progressive_connection_availability.v1
+    evidence_contract_ref: evidence.progressive_connection_availability.v1
+
+  - id: op.geometric_progressive_corridor_anchor_set.v1
+    kind: Operationalization
+    display_name: Geometric Progressive Corridor From Anchor Set
+    description: Represent a clear forward connection from a generic anchor set to an attacking teammate over an interval.
+    concept_refs: [concept.progressive_connection_availability]
+    semantic_basis: DETERMINISTIC
+    required_modalities: [tracking]
+    applicability: [anchor_set_available, attacking_teammates_available, defending_outfield_available]
+    inputs:
+      - name: anchors
+        type: {container: EpisodeSet, value: AnchorRef, quantity: anchor_set, unit: none, entity_scope: anchor}
+    outputs:
+      - name: episodes
+        type: {container: RelationEpisodeSet, value: RelationRef, quantity: progressive_corridor, unit: none, entity_scope: relation}
