@@ -0,0 +1,4000 @@
+catalog_id: priori.soccer.standard_library
+catalog_version: 0.1.0-concept
+snapshot_date: '2026-06-23'
+status: PROPOSAL
+declaration_count: 741
+family_count: 26
+north_star: A rich typed football algebra over a small audited runtime kernel.
+semantic_tiers:
+  OBSERVATION: Provider or canonical source fact.
+  DETERMINISTIC: Reproducible derivation from declared inputs.
+  INFERRED_CANDIDATE: Evidence-backed interpretation that does not claim intention.
+  MODELLED: Probabilistic, learned, value, or counterfactual output.
+  OPERATOR: Typed composition or temporal/set operator.
+  EVIDENCE: Provenance, replay, validation, or governance output.
+truth_model:
+  predicate_truth:
+  - PASS
+  - FAIL
+  - UNKNOWN
+  evaluation_disposition:
+  - EVALUATED
+  - NOT_APPLICABLE
+  - CONFLICT
+  data_quality:
+  - VALID
+  - DEGRADED
+  - INSUFFICIENT
+  semantic_basis:
+  - OBSERVED
+  - DERIVED
+  - INFERRED_CANDIDATE
+  - MODELLED
+runtime_types:
+- type: Scalar<T>
+  definition: A unit-bearing atomic value.
+- type: Signal<T>
+  definition: A value indexed by canonical match time or frame.
+- type: Point / Vector / Transform
+  definition: Geometry with explicit coordinate and reference frames.
+- type: Trajectory
+  definition: Time-indexed entity or ball path with uncertainty.
+- type: EntitySet / OrderedEntitySet
+  definition: Typed actors, including expected, observed, missing, and excluded membership.
+- type: Region / RegionSet
+  definition: Static or dynamic spatial areas.
+- type: Line / Curve
+  definition: Ordered structural boundaries such as units and offside lines.
+- type: Field<T>
+  definition: A scalar, vector, probability, control, pressure, or value surface over the pitch.
+- type: Graph
+  definition: Dynamic nodes and typed interaction edges.
+- type: Distribution<T>
+  definition: Calibrated alternatives or uncertain values, never collapsed prematurely.
+- type: Anchor / AnchorSet
+  definition: Reference moments with boundary and alignment uncertainty.
+- type: Episode / EpisodeSet
+  definition: Bounded intervals with start/end semantics.
+- type: RelationEpisodeSet
+  definition: A typed relation among entities or regions over time.
+- type: SequenceSet
+  definition: Ordered episodes and relations with continuity constraints.
+- type: CandidateSet
+  definition: Ranked competing hypotheses with evidence.
+- type: EvaluationSet
+  definition: Per-anchor truth, quality, coverage, reasons, and witnesses.
+- type: UncertaintyEnvelope
+  definition: Spatial, temporal, identity, model, and boundary uncertainty.
+- type: EvidenceBundle
+  definition: Frames, entities, geometry, measurements, traces, provenance, and replay.
+capability_contract_fields:
+- stable id and semantic version
+- 'semantic claim level: OBSERVATION | DETERMINISTIC | INFERRED_CANDIDATE | MODELLED'
+- 'authorability: COMPILER_LOWERING | AGENT_COMPOSABLE | TRUSTED_RECIPE_ONLY | USER_TACTICAL'
+- typed inputs and outputs
+- units, coordinate frame, perspective, and entity scope
+- temporal anchor, boundary, continuity, and resampling semantics
+- required and optional data modalities
+- parameter schema, allowed bounds, and system-owned defaults
+- coverage denominator and active-player policy
+- uncertainty propagation and alternative-hypothesis policy
+- predicate truth policy and typed UNKNOWN reasons
+- evidence fields and replay overlays
+- limitations and prohibited claims
+- mathematical invariants, synthetic tests, gold examples, and cross-provider conformance
+- performance budget, caching behavior, and deterministic result identity
+- deprecation and migration policy
+implementation_kernels:
+- entity selection and active-membership resolution
+- coordinate/reference-frame transformation
+- signal smoothing, differentiation, and uncertainty propagation
+- point, line, region, corridor, and field geometry
+- dynamic-region construction and Boolean geometry
+- reachability / time-to-intercept inference
+- state inference with multiple hypotheses
+- transition and change-point detection
+- episode extraction with hysteresis and gap tolerance
+- typed entity and relation joins
+- dynamic graph construction
+- temporal interval algebra and sequence matching
+- aggregation with coverage-aware denominators
+- tri-state thresholding
+- learned-model inference with domain checks
+- evidence projection and deterministic result identity
+families:
+- id: data_quality
+  title: Data quality, synchronization, and provenance
+  purpose: Make every downstream claim conditional on what was actually observed, aligned, and trustworthy.
+  default_modalities:
+  - tracking
+  - events
+  - match_sheet
+  capabilities:
+  - id: tracking_presence
+    definition: Reports whether each required entity is observed at each frame.
+    output_type: entity_set_signal
+    semantic_tier: OBSERVATION
+    status: PROPOSED
+  - id: tracking_coverage_ratio
+    definition: Measures observed-frame coverage for an entity, set, or episode.
+    output_type: scalar_or_frame_signal
+    semantic_tier: DETERMINISTIC
+    status: PROPOSED
+  - id: sample_gap_episode
+    definition: Finds contiguous gaps in the expected tracking sample stream.
+    output_type: episode_set
+    semantic_tier: DETERMINISTIC
+    status: PROPOSED
+  - id: irregular_sampling_signal
+    definition: Measures deviation from the declared frame interval.
+    output_type: frame_signal
+    semantic_tier: DETERMINISTIC
+    status: PROPOSED
+  - id: coordinate_outlier_candidate
+    definition: Flags implausible positions, jumps, or off-pitch coordinates without silently correcting them.
+    output_type: evaluation_set
+    semantic_tier: INFERRED_CANDIDATE
+    status: PROPOSED
+  - id: kinematic_outlier_candidate
+    definition: Flags implausible speed, acceleration, jerk, or turn-rate observations.
+    output_type: evaluation_set
+    semantic_tier: INFERRED_CANDIDATE
+    status: PROPOSED
+  - id: identity_swap_candidate
+    definition: Detects trajectory discontinuities consistent with two tracked identities being swapped.
+    output_type: relation_episode_set
+    semantic_tier: INFERRED_CANDIDATE
+    status: PROPOSED
+  - id: ball_track_quality
+    definition: Summarizes ball visibility, continuity, height reliability, and physical plausibility.
+    output_type: evaluation_set
+    semantic_tier: INFERRED_CANDIDATE
+    status: PROPOSED
+  - id: pitch_calibration_quality
+    definition: Measures whether coordinate extents and landmark geometry agree with declared pitch dimensions.
+    output_type: evaluation_set
+    semantic_tier: DETERMINISTIC
+    status: PROPOSED
+  - id: event_tracking_alignment_candidate
+    definition: Returns ranked physical frame candidates for a provider event.
+    output_type: candidate_set
+    semantic_tier: INFERRED_CANDIDATE
+    status: PROPOSED
+  - id: event_tracking_alignment_confidence
+    definition: Quantifies confidence and ambiguity in an event-to-tracking alignment.
+    output_type: distribution_signal
+    semantic_tier: MODELLED
+    status: PROPOSED
+  - id: clock_offset_estimate
+    definition: Estimates local event-to-tracking clock offset over a declared interval.
+    output_type: frame_or_episode_signal
+    semantic_tier: INFERRED_CANDIDATE
+    status: PROPOSED
+  - id: clock_drift_estimate
+    definition: Estimates changing clock offset rather than assuming one constant shift.
+    output_type: frame_signal
+    semantic_tier: INFERRED_CANDIDATE
+    status: PROPOSED
+  - id: provider_event_conflict
+    definition: Identifies contradictions between event labels, tracking evidence, and match state.
+    output_type: evaluation_set
+    semantic_tier: INFERRED_CANDIDATE
+    status: PROPOSED
+  - id: interpolation_mask
+    definition: Records exactly which values were interpolated and by which method.
+    output_type: entity_set_signal
+    semantic_tier: OBSERVATION
+    status: PROPOSED
+  - id: smoothing_provenance
+    definition: Records filter method, parameters, input rate, and boundary handling for derived kinematics.
+    output_type: evidence_record
+    semantic_tier: EVIDENCE
+    status: PROPOSED
+  - id: source_provenance
+    definition: Carries provider, file, schema version, ingestion version, and source record identifiers.
+    output_type: evidence_record
+    semantic_tier: EVIDENCE
+    status: PROPOSED
+  - id: measurement_uncertainty
+    definition: Attaches position, time, and derived-value uncertainty to any runtime value.
+    output_type: uncertainty_envelope
+    semantic_tier: DETERMINISTIC
+    status: PROPOSED
+  - id: required_entity_coverage
+    definition: Checks whether all entities required by a capability are present for its full evaluation window.
+    output_type: evaluation_set
+    semantic_tier: DETERMINISTIC
+    status: PROPOSED
+  - id: quality_reason_histogram
+    definition: Aggregates missingness, degradation, conflict, and failure reasons over a query scope.
+    output_type: table_value
+    semantic_tier: EVIDENCE
+    status: PROPOSED
+- id: match_context
+  title: Match clock, laws, and contextual state
+  purpose: Represent the game context that changes the meaning of otherwise identical spatial patterns.
+  default_modalities:
+  - tracking
+  - events
+  - match_sheet
+  capabilities:
+  - id: period_episode
+    definition: Returns canonical first-half, second-half, extra-time, and shootout intervals.
+    output_type: episode_set
+    semantic_tier: OBSERVATION
+    status: PROPOSED
+  - id: canonical_match_clock
+    definition: Maps every frame and event to one monotonic match-time reference.
+    output_type: frame_signal
+    semantic_tier: DETERMINISTIC
+    status: PROPOSED
+  - id: ball_in_play_state
+    definition: Classifies each frame as active play, inactive play, or unknown.
+    output_type: enum_signal
+    semantic_tier: INFERRED_CANDIDATE
+    status: PROPOSED
+  - id: restart_state
+    definition: Classifies the current restart context without yet inferring the tactical routine.
+    output_type: enum_signal
+    semantic_tier: INFERRED_CANDIDATE
+    status: PROPOSED
+  - id: restart_episode
+    definition: Bounds a restart from award/setup through the return to open play.
+    output_type: episode_set
+    semantic_tier: INFERRED_CANDIDATE
+    status: PROPOSED
+  - id: score_state
+    definition: Returns scoreline and goal difference from each team's perspective.
+    output_type: record_signal
+    semantic_tier: DETERMINISTIC
+    status: PROPOSED
+  - id: match_status_state
+    definition: Represents leading, level, trailing, and knockout aggregate context.
+    output_type: enum_signal
+    semantic_tier: DETERMINISTIC
+    status: PROPOSED
+  - id: remaining_time
+    definition: Returns regulation or extra-time remaining under a declared clock policy.
+    output_type: frame_signal
+    semantic_tier: DETERMINISTIC
+    status: PROPOSED
+  - id: stoppage_time_state
+    definition: Identifies announced or inferred added-time intervals.
+    output_type: episode_set
+    semantic_tier: INFERRED_CANDIDATE
+    status: PROPOSED
+  - id: numerical_strength_state
+    definition: Returns active-player counts and numerical advantage by team.
+    output_type: record_signal
+    semantic_tier: DETERMINISTIC
+    status: PROPOSED
+  - id: pitch_dimensions
+    definition: Returns trusted pitch length, width, goal, box, and landmark geometry.
+    output_type: geometry_record
+    semantic_tier: OBSERVATION
+    status: PROPOSED
+  - id: attacking_direction
+    definition: Returns each team's attacking-axis transform by period.
+    output_type: transform_signal
+    semantic_tier: DETERMINISTIC
+    status: PROPOSED
+  - id: competition_context
+    definition: Carries competition, season, round, venue, and rule-set metadata.
+    output_type: record_value
