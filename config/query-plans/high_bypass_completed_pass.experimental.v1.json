    "schema_version": "1.0",
    "recipe_id": "high_bypass_completed_pass_v1",
    "recipe_version": "0.1.0",
    "display_name": "High-Bypass Completed Pass",
    "description": "Experimental composition that finds completed controlled passes where the ball progresses forward and at least a declared number of opposition outfield players move from goal-side of the ball at release to behind the ball at controlled reception.",
    "default_unknown_evidence_policy": "exclude_candidate",
    "allowed_claims": [
      "The event data identified a completed pass candidate.",
      "Tracking data confirmed physical release and controlled reception.",
      "The measured action bypassed the declared number of opposition outfield players.",
      "The replay coordinates come from canonical source frames."
    ],
    "disallowed_claims": [
      "The pass was optimal.",
      "The pass probability was high.",
      "The passer intended to break a defensive line.",
      "The pass alone caused every opponent to be bypassed.",
      "The result proves which defensive line was broken.",
      "The result is backed by licensed match video."
    ],
    "limitations": [
      "Experimental plan; not an approved recipe.",
      "Bypass count is measured relative to ball position at release and controlled reception.",
      "Goalkeepers are excluded from the opposition denominator.",
      "No defensive-line model, offside model, pass probability, body-orientation model, or intent model is evaluated."
    ],
    "output_classifications": [
      "HIGH_BYPASS_COMPLETED_PASS"
    ],
    "parameters": [
      {
        "name": "minimum_forward_progression_m",
        "payload_type": "number",
        "unit": "metre",
        "required": false,
        "default": {
          "payload_type": "number",
          "unit": "metre",
          "value": 8.0
        },
        "description": "Minimum forward ball progression from physical release to controlled reception."
      },
      {
        "name": "minimum_bypassed_opponents",
        "payload_type": "number",
        "unit": "count",
        "required": false,
        "default": {
          "payload_type": "number",
          "unit": "count",
          "value": 5
        },
        "description": "Minimum opposition outfield players bypassed by the completed action."
      },
      {
        "name": "goal_side_buffer_m",
        "payload_type": "number",
        "unit": "metre",
        "required": false,
        "default": {
          "payload_type": "number",
          "unit": "metre",
          "value": 1.0
        },
        "description": "Release-frame buffer for deciding whether an opponent is goal-side of the ball."
      },
      {
        "name": "bypassed_buffer_m",
        "payload_type": "number",
        "unit": "metre",
        "required": false,
        "default": {
          "payload_type": "number",
          "unit": "metre",
          "value": 1.0
        },
        "description": "Reception-frame buffer for deciding whether an opponent is behind the ball."
      }
    ]
  },
